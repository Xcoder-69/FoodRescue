# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Option 1 (Local): Place serviceAccountKey.json in root folder
# Option 2 (Production): Paste the full JSON content as a string below
FIREBASE_SERVICE_ACCOUNT=

# Firebase Storage bucket (format: your-project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=foodrescue-xxxx.appspot.com

# Your Firebase Project ID
FIREBASE_PROJECT_ID=foodrescue-xxxx

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── OpenRouteService (Free routing API) ─────────────────────────────────────
ORS_API_KEY=your_openrouteservice_api_key

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (for CORS)
# Example: https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=*

# ─── Optional: Admin Setup ───────────────────────────────────────────────────
# First admin user UID (set manually after creating account)
ADMIN_UID=

# ─── Optional: App Config ────────────────────────────────────────────────────
# Maximum pickup radius in km
MAX_PICKUP_RADIUS_KM=20

# Donation expiry reminder time in minutes before expiry
DONATION_REMINDER_MINUTES=30
