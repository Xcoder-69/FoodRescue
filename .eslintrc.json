{
  "env": {
    "node": true,
    "es2022": true,
    "commonjs": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next" }],
    "no-console": "off",
    "no-undef": "error",
    "semi": ["warn", "always"],
    "eqeqeq": ["warn", "always"],
    "no-var": "warn",
    "prefer-const": "warn"
  }
}
